# Cmssy configuration

# Cmssy API Token (get from Dashboard → API Tokens)
# Required scopes: marketplace:publish (for marketplace) or workspace:write (for workspace)
CMSSY_API_TOKEN=

# Workspace ID (optional, for workspace publish)
# Get from Dashboard → Workspace Settings
CMSSY_WORKSPACE_ID=

# ─── Headless frontend (@cmssy/next + @cmssy/react) ───────────────
# Public delivery API is keyed by workspace slug (no token needed).
CMSSY_WORKSPACE_SLUG=
# Workspace ID exposed to client blocks (blog-posts listing). Public, safe to ship.
NEXT_PUBLIC_CMSSY_WORKSPACE_ID=
# Secret guarding the draft-preview bridge (any random string)
CMSSY_DRAFT_SECRET=
# Secret guarding the /api/revalidate webhook (any random string)
CMSSY_REVALIDATE_SECRET=

# Optional - apiUrl + editorOrigin default to cmssy cloud; set only for
# local dev / self-hosting:
# CMSSY_API_URL=http://localhost:4000/graphql   # default: https://api.cmssy.io/graphql
# CMSSY_EDITOR_ORIGIN=http://localhost:3001     # default: https://www.cmssy.io

# Local preview content source (development only, ignored in production):
#   dev  = render your own isolated dev-draft overlay on every request
#   live = render published content (default when unset)
# Requires CMSSY_API_TOKEN above - it is the set-once credential that
# identifies whose dev drafts to read; this flag is the mode switch.
# CMSSY_PREVIEW=live

# Analytics (optional, dev-owned). Set in Vercel env.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
